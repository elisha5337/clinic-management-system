@model ClinicManagementSystem.ViewModels.Dashboard.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<!-- ── Stat Cards ──────────────────────────────────────────────── -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card bg-primary">
            <div class="stat-value">@Model.TotalPatients</div>
            <div class="stat-label">Total Patients</div>
            <i class="bi bi-people stat-icon"></i>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card bg-success">
            <div class="stat-value">@Model.TotalDoctors</div>
            <div class="stat-label">Available Doctors</div>
            <i class="bi bi-person-badge stat-icon"></i>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card bg-info">
            <div class="stat-value">@Model.TodayAppointments</div>
            <div class="stat-label">Today's Appointments</div>
            <i class="bi bi-calendar-check stat-icon"></i>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card bg-warning">
            <div class="stat-value">@Model.PendingAppointments</div>
            <div class="stat-label">Pending (Scheduled)</div>
            <i class="bi bi-hourglass-split stat-icon"></i>
        </div>
    </div>
</div>

<!-- ── Charts Row ─────────────────────────────────────────────── -->
<div class="row g-3 mb-4">
    <!-- Bar chart — appointments this week -->
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-bar-chart me-2 text-primary"></i>Appointments This Week</span>
            </div>
            <div class="card-body">
                <canvas id="weeklyChart" height="100"></canvas>
            </div>
        </div>
    </div>

    <!-- Pie chart — by status -->
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                <span><i class="bi bi-pie-chart me-2 text-primary"></i>By Status</span>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center">
                <canvas id="statusChart" height="200"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- ── Recent Appointments ────────────────────────────────────── -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-clock-history me-2 text-primary"></i>Recent Appointments</span>
        <a asp-controller="Appointments" asp-action="Index" class="btn btn-sm btn-outline-primary">
            View All
        </a>
    </div>
    <div class="card-body p-0">
        @if (!Model.RecentAppointments.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-calendar-x fs-1 d-block mb-2"></i>
                No appointments found.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Date & Time</th>
                            <th>Reason</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var appt in Model.RecentAppointments)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@appt.Patient.FullName</div>
                                </td>
                                <td>@appt.Doctor.FullName</td>
                                <td>
                                    <div>@appt.AppointmentDate.ToString("MMM dd, yyyy")</div>
                                    <small class="text-muted">@appt.AppointmentDate.ToString("hh:mm tt")</small>
                                </td>
                                <td>
                                    <span class="text-truncate d-inline-block" style="max-width:160px"
                                          title="@appt.ReasonForVisit">
                                        @appt.ReasonForVisit
                                    </span>
                                </td>
                                <td>
                                    @{
                                        var (badgeClass, label) = appt.Status switch
                                        {
                                            ClinicManagementSystem.Models.AppointmentStatus.Scheduled  => ("badge-scheduled",  "Scheduled"),
                                            ClinicManagementSystem.Models.AppointmentStatus.InProgress => ("badge-inprogress", "In Progress"),
                                            ClinicManagementSystem.Models.AppointmentStatus.Completed  => ("badge-completed",  "Completed"),
                                            ClinicManagementSystem.Models.AppointmentStatus.Cancelled  => ("badge-cancelled",  "Cancelled"),
                                            _ => ("badge-secondary", appt.Status.ToString())
                                        };
                                    }
                                    <span class="status-badge @badgeClass">@label</span>
                                </td>
                                <td>
                                    <a asp-controller="Appointments" asp-action="Details"
                                       asp-route-id="@appt.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    // ── Weekly bar chart ──────────────────────────────────────────
    new Chart(document.getElementById('weeklyChart'), {
        type: 'bar',
        data: {
            labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.WeekDayLabels)),
            datasets: [{
                label: 'Appointments',
                data:  @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.WeekDayCounts)),
                backgroundColor: 'rgba(45, 106, 159, 0.75)',
                borderColor:     'rgba(26, 60, 94, 1)',
                borderWidth: 1,
                borderRadius: 6
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: { stepSize: 1 },
                    grid: { color: '#f1f5f9' }
                },
                x: { grid: { display: false } }
            }
        }
    });

    // ── Status pie chart ──────────────────────────────────────────
    new Chart(document.getElementById('statusChart'), {
        type: 'doughnut',
        data: {
            labels: ['Scheduled', 'In Progress', 'Completed', 'Cancelled'],
            datasets: [{
                data: [
                    @Model.ScheduledCount,
                    @Model.InProgressCount,
                    @Model.CompletedCount,
                    @Model.CancelledCount
                ],
                backgroundColor: ['#dbeafe', '#fef9c3', '#dcfce7', '#fee2e2'],
                borderColor:     ['#1d4ed8', '#854d0e', '#166534', '#991b1b'],
                borderWidth: 2
            }]
        },
        options: {
            responsive: true,
            cutout: '65%',
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: { font: { size: 11 }, padding: 12 }
                }
            }
        }
    });
</script>
}
