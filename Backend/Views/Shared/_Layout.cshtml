@using Microsoft.AspNetCore.Identity
@using ClinicManagementSystem.Models
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager

@{
    var currentUser = await UserManager.GetUserAsync(User);
    var userRoles   = currentUser != null
        ? await UserManager.GetRolesAsync(currentUser)
        : new List<string>();
    var role        = userRoles.FirstOrDefault() ?? "Staff";
    var currentPath = Context.Request.Path.Value ?? "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Clinic MS</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="app-wrapper">

    <!-- ── Sidebar ──────────────────────────────────────────────── -->
    <aside class="sidebar" id="sidebar">

        <!-- Brand -->
        <a class="sidebar-brand" asp-controller="Dashboard" asp-action="Index">
            <div class="brand-icon"><i class="bi bi-hospital"></i></div>
            <div>
                <div class="brand-text">Clinic MS</div>
                <div class="brand-sub">Management System</div>
            </div>
        </a>

        <!-- Main Navigation -->
        <div class="sidebar-section">
            <div class="sidebar-section-label">Main</div>
            <nav class="sidebar-nav">
                <a class="nav-link @(currentPath == "/Dashboard" || currentPath == "/" ? "active" : "")"
                   asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>
            </nav>
        </div>

        <!-- Patient Management — all roles can view -->
        <div class="sidebar-section">
            <div class="sidebar-section-label">Patients</div>
            <nav class="sidebar-nav">
                <a class="nav-link @(currentPath.StartsWith("/Patients") ? "active" : "")"
                   asp-controller="Patients" asp-action="Index">
                    <i class="bi bi-people"></i> All Patients
                </a>

                @if (User.IsInRole("Receptionist"))
                {
                    <a class="nav-link @(currentPath == "/Patients/Create" ? "active" : "")"
                       asp-controller="Patients" asp-action="Create">
                        <i class="bi bi-person-plus"></i> Register Patient
                    </a>
                }
            </nav>
        </div>

        <!-- Appointments -->
        <div class="sidebar-section">
            <div class="sidebar-section-label">Appointments</div>
            <nav class="sidebar-nav">
                <a class="nav-link @(currentPath.StartsWith("/Appointments") ? "active" : "")"
                   asp-controller="Appointments" asp-action="Index">
                    <i class="bi bi-calendar3"></i> Appointments
                </a>

                @if (User.IsInRole("Receptionist"))
                {
                    <a class="nav-link @(currentPath == "/Appointments/Create" ? "active" : "")"
                       asp-controller="Appointments" asp-action="Create">
                        <i class="bi bi-calendar-plus"></i> Book Appointment
                    </a>
                }

                @if (User.IsInRole("Nurse"))
                {
                    <a class="nav-link @(currentPath.StartsWith("/Vitals") ? "active" : "")"
                       asp-controller="Appointments" asp-action="Index"
                       asp-route-status="Scheduled">
                        <i class="bi bi-heart-pulse"></i> Record Vitals
                    </a>
                }
            </nav>
        </div>

        <!-- Doctors — all roles can view -->
        <div class="sidebar-section">
            <div class="sidebar-section-label">Doctors</div>
            <nav class="sidebar-nav">
                <a class="nav-link @(currentPath.StartsWith("/Doctors") ? "active" : "")"
                   asp-controller="Doctors" asp-action="Index">
                    <i class="bi bi-person-badge"></i> Doctors
                </a>
            </nav>
        </div>

        <!-- Admin section — Receptionist only -->
        @if (User.IsInRole("Receptionist"))
        {
            <div class="sidebar-section">
                <div class="sidebar-section-label">Administration</div>
                <nav class="sidebar-nav">
                    <a class="nav-link @(currentPath == "/Account/Register" ? "active" : "")"
                       asp-controller="Account" asp-action="Register">
                        <i class="bi bi-person-gear"></i> Manage Users
                    </a>
                </nav>
            </div>
        }

        <!-- Sidebar footer — logged-in user -->
        <div class="sidebar-footer">
            <div class="sidebar-user">
                <div class="user-avatar">
                    <i class="bi bi-person-fill"></i>
                </div>
                <div class="flex-grow-1 overflow-hidden">
                    <div class="user-name text-truncate">@(currentUser?.FullName ?? "User")</div>
                    <div class="user-role">@role</div>
                </div>
            </div>
        </div>
    </aside>

    <!-- Mobile overlay -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- ── Main content ──────────────────────────────────────────── -->
    <div class="main-content">

        <!-- Top bar -->
        <header class="topbar">
            <!-- Mobile hamburger -->
            <button class="btn btn-sm btn-outline-secondary d-md-none me-2"
                    id="sidebarToggle" type="button">
                <i class="bi bi-list fs-5"></i>
            </button>

            <span class="topbar-title">@(ViewData["Title"] ?? "Dashboard")</span>

            <div class="topbar-actions">
                <!-- Role badge -->
                <span class="badge rounded-pill px-3 py-2"
                      style="background:#e8f0fe; color:#1a3c5e; font-size:0.75rem;">
                    <i class="bi bi-shield-check me-1"></i>@role
                </span>

                <!-- Logout -->
                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-danger"
                            title="Sign out">
                        <i class="bi bi-box-arrow-right me-1"></i>
                        <span class="d-none d-sm-inline">Sign Out</span>
                    </button>
                </form>
            </div>
        </header>

        <!-- Toast notifications -->
        <div class="toast-container">
            @if (TempData["Success"] != null)
            {
                <div class="toast align-items-center text-bg-success border-0 show"
                     role="alert" data-bs-autohide="true" data-bs-delay="4000">
                    <div class="d-flex">
                        <div class="toast-body">
                            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                        </div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto"
                                data-bs-dismiss="toast"></button>
                    </div>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="toast align-items-center text-bg-danger border-0 show"
                     role="alert" data-bs-autohide="true" data-bs-delay="5000">
                    <div class="d-flex">
                        <div class="toast-body">
                            <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
                        </div>
                        <button type="button" class="btn-close btn-close-white me-2 m-auto"
                                data-bs-dismiss="toast"></button>
                    </div>
                </div>
            }
        </div>

        <!-- Page body -->
        <main class="page-content">
            @RenderBody()
        </main>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

<script>
    // Mobile sidebar toggle
    const sidebar  = document.getElementById('sidebar');
    const overlay  = document.getElementById('sidebarOverlay');
    const toggle   = document.getElementById('sidebarToggle');

    toggle?.addEventListener('click', () => {
        sidebar.classList.toggle('show');
        overlay.classList.toggle('show');
    });

    overlay?.addEventListener('click', () => {
        sidebar.classList.remove('show');
        overlay.classList.remove('show');
    });

    // Auto-initialise all Bootstrap toasts
    document.querySelectorAll('.toast').forEach(el => {
        new bootstrap.Toast(el).show();
    });
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
