@model ClinicManagementSystem.Models.ErrorViewModel
@{
    ViewData["Title"] = "Error";
    Layout = "_AuthLayout";
}

<div class="text-center py-3">
    <div class="mb-3" style="font-size:4rem; color:#dc3545;">
        <i class="bi bi-exclamation-triangle"></i>
    </div>
    <h5 class="fw-bold text-danger mb-2">Something Went Wrong</h5>
    <p class="text-muted small mb-1">
        An unexpected error occurred. Please try again or contact your administrator.
    </p>
    @if (Model.ShowRequestId)
    {
        <p class="text-muted" style="font-size:0.7rem;">
            Request ID: <code>@Model.RequestId</code>
        </p>
    }
    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary px-4 mt-2">
        <i class="bi bi-house me-2"></i>Back to Dashboard
    </a>
</div>
