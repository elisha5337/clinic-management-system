@model ClinicManagementSystem.ViewModels.Patients.PatientDetailsViewModel
@{
    ViewData["Title"] = Model.Patient.FullName;
    var p = Model.Patient;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1 fw-bold">
            <i class="bi bi-person-lines-fill me-2 text-primary"></i>Patient Record
        </h4>
        <p class="text-muted mb-0 small">Full medical profile</p>
    </div>
    <div class="d-flex gap-2">
        @if (User.IsInRole("Receptionist"))
        {
            <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-outline-primary">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>
        }
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="row g-3 mb-4">
    <!-- Patient info card -->
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header">
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center
                                justify-content-center text-primary fw-bold"
                         style="width:52px;height:52px;font-size:1.3rem;flex-shrink:0">
                        @p.FullName[0]
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold">@p.FullName</h5>
                        <small class="text-muted">
                            @p.Age years old &bull; @p.Gender &bull;
                            @if (!string.IsNullOrEmpty(p.BloodType))
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger">@p.BloodType</span>
                            }
                        </small>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <label class="form-label text-muted small mb-1">Date of Birth</label>
                        <div class="fw-medium">@p.DateOfBirth.ToString("MMMM dd, yyyy")</div>
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label text-muted small mb-1">Phone</label>
                        <div class="fw-medium">
                            <i class="bi bi-telephone me-1 text-muted"></i>@p.Phone
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label text-muted small mb-1">Email</label>
                        <div class="fw-medium">@(p.Email ?? "—")</div>
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label text-muted small mb-1">Address</label>
                        <div class="fw-medium">@(p.Address ?? "—")</div>
                    </div>
                    <div class="col-12">
                        <hr class="my-1" />
                        <label class="form-label text-muted small mb-1">
                            <i class="bi bi-person-exclamation me-1"></i>Emergency Contact
                        </label>
                        <div class="fw-medium">
                            @(p.EmergencyContactName ?? "—")
                            @if (!string.IsNullOrEmpty(p.EmergencyContactPhone))
                            {
                                <span class="text-muted ms-2">@p.EmergencyContactPhone</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats sidebar -->
    <div class="col-lg-4">
        <div class="row g-3">
            <div class="col-6 col-lg-12">
                <div class="card text-center p-3">
                    <div class="fs-2 fw-bold text-primary">@Model.TotalAppointments</div>
                    <div class="text-muted small">Total Appointments</div>
                </div>
            </div>
            <div class="col-6 col-lg-12">
                <div class="card text-center p-3">
                    <div class="fs-2 fw-bold text-success">@Model.CompletedAppointments</div>
                    <div class="text-muted small">Completed</div>
                </div>
            </div>
            @if (Model.LastAppointment != null)
            {
                <div class="col-12">
                    <div class="card p-3">
                        <div class="text-muted small mb-1">Last Visit</div>
                        <div class="fw-semibold">
                            @Model.LastAppointment.AppointmentDate.ToString("MMM dd, yyyy")
                        </div>
                        <div class="text-muted small">
                            @Model.LastAppointment.Doctor.FullName
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Appointment history -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-calendar3 me-2 text-primary"></i>Appointment History</span>
        @if (User.IsInRole("Receptionist"))
        {
            <a asp-controller="Appointments" asp-action="Create"
               asp-route-patientId="@p.Id" class="btn btn-sm btn-primary">
                <i class="bi bi-calendar-plus me-1"></i>Book Appointment
            </a>
        }
    </div>
    <div class="card-body p-0">
        @if (!Model.Appointments.Any())
        {
            <div class="text-center py-4 text-muted">
                <i class="bi bi-calendar-x fs-2 d-block mb-2"></i>No appointments yet.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Date & Time</th>
                            <th>Doctor</th>
                            <th>Reason</th>
                            <th>Status</th>
                            <th>Vitals</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var appt in Model.Appointments)
                        {
                            <tr>
                                <td>
                                    <div>@appt.AppointmentDate.ToString("MMM dd, yyyy")</div>
                                    <small class="text-muted">@appt.AppointmentDate.ToString("hh:mm tt")</small>
                                </td>
                                <td>@appt.Doctor.FullName</td>
                                <td>
                                    <span class="text-truncate d-inline-block" style="max-width:150px"
                                          title="@appt.ReasonForVisit">
                                        @appt.ReasonForVisit
                                    </span>
                                </td>
                                <td>
                                    @{
                                        var (cls, lbl) = appt.Status switch
                                        {
                                            ClinicManagementSystem.Models.AppointmentStatus.Scheduled  => ("badge-scheduled",  "Scheduled"),
                                            ClinicManagementSystem.Models.AppointmentStatus.InProgress => ("badge-inprogress", "In Progress"),
                                            ClinicManagementSystem.Models.AppointmentStatus.Completed  => ("badge-completed",  "Completed"),
                                            ClinicManagementSystem.Models.AppointmentStatus.Cancelled  => ("badge-cancelled",  "Cancelled"),
                                            _ => ("", appt.Status.ToString())
                                        };
                                    }
                                    <span class="status-badge @cls">@lbl</span>
                                </td>
                                <td>
                                    @if (appt.Vitals != null)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success">
                                            <i class="bi bi-check-circle me-1"></i>Recorded
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td>
                                    <a asp-controller="Appointments" asp-action="Details"
                                       asp-route-id="@appt.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
